import sys

def is_vowel(letter):
    # 'y' is explicitly included as a vowel in this challenge
    return letter in ['a', 'e', 'i', 'o', 'u', 'y']

def score_words(words):
    score = 0
    for word in words:
        num_vowels = 0
        for letter in word:
            if is_vowel(letter):
                num_vowels += 1
        
        # Correct logic: Even vowels = 2 points, Odd vowels = 1 point
        if num_vowels % 2 == 0:
            score += 2
        else:
            score += 1
            
    return score

def main():
    # Read number of words
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    n = int(input_data[0])
    words = input_data[1:]
    
    # Calculate and print the result
    print(score_words(words))

if __name__ == "__main__":
    main()
