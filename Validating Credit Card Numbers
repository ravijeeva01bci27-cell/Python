import re

def validate_credit_card():
    # Read number of test cases
    try:
        n = int(input().strip())
    except EOFError:
        return

    # Process each credit card number
    for _ in range(n):
        card = input().strip()
        
        # 1. Structural Regex
        # Starts with 4,5,6; total 16 digits; groups of 4 separated by '-' or nothing
        struct_pattern = r'^[456]\d{3}(-?\d{4}){3}$'
        
        # 2. Consecutive Digits Regex (must NOT match)
        # Check against string with hyphens removed
        repeat_pattern = r'(\d)\1{3,}'
        
        if re.match(struct_pattern, card):
            # Remove hyphens for the repetition check
            card_no_hyphens = card.replace("-", "")
            
            # Check for 4+ consecutive repeated digits
            if not re.search(repeat_pattern, card_no_hyphens):
                print("Valid")
            else:
                print("Invalid")
        else:
            print("Invalid")

if __name__ == "__main__":
    validate_credit_card()
